# Google AI / Gemini API
# Option A: Gemini API (GOOGLE_GENAI_USE_VERTEXAI=False)
GOOGLE_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI (GOOGLE_GENAI_USE_VERTEXAI=True)
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=global

# Which backend to use: False = Gemini API, True = Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=False

# Optional: Spoonacular API (not currently used — OpenFoodFacts is used instead)
# SPOONACULAR_API_KEY=your_spoonacular_key_here

# Optional: deployment only
# LOGS_BUCKET_NAME=your_gcs_bucket_name
# ALLOW_ORIGINS=http://localhost:3000
